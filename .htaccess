# .htaccess - Configurações do Apache para Roteamento
# Ativa o motor de reescrita de URL
RewriteEngine On
# Condição: Se a requisição não for para um arquivo existente...
RewriteCond %{REQUEST_FILENAME} !-f
# Condição: E também não for para um diretório existente...
RewriteCond %{REQUEST_FILENAME} !-d
# Regra: Redireciona a requisição para o index.php
# O parâmetro [L] impede que outras regras sejam aplicadas
RewriteRule ^(.*)$ index.php [L]

<IfModule mod_rewrite.c>
    Options +FollowSymLinks
    RewriteEngine On
    RewriteBase /tmptestepizza.php/

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index2.php?url=$1 [L,QSA]
</IfModule>